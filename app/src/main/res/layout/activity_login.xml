<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_dark" android:fillViewport="true">
  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="vertical" android:padding="28dp" android:gravity="center">

    <!-- Logo -->
    <TextView android:layout_width="72dp" android:layout_height="72dp"
        android:text="🔐" android:textSize="36sp" android:gravity="center"
        android:background="@drawable/circle_bg_blue"
        android:layout_marginTop="48dp" android:layout_marginBottom="12dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="BabaSitaRam Pro" android:textSize="24sp" android:textStyle="bold"
        android:textColor="@color/text_primary" android:layout_marginBottom="4dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Password Manager" android:textSize="13sp" android:textColor="@color/text_secondary"
        android:layout_marginBottom="36dp"/>

    <!-- SETUP -->
    <LinearLayout android:id="@+id/layoutSetup" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:text="New Vault Setup" android:textSize="18sp" android:textStyle="bold"
          android:textColor="@color/text_primary" android:layout_marginBottom="20dp"/>
      <com.google.android.material.textfield.TextInputLayout
          style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
          android:layout_width="match_parent" android:layout_height="wrap_content"
          android:hint="Mobile Number" android:layout_marginBottom="14dp"
          app:boxStrokeColor="@color/accent_blue" app:hintTextColor="@color/accent_blue">
        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etPhone"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:inputType="phone" android:textColor="@color/text_primary"/>
      </com.google.android.material.textfield.TextInputLayout>
      <com.google.android.material.textfield.TextInputLayout
          style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
          android:layout_width="match_parent" android:layout_height="wrap_content"
          android:hint="Master Password" android:layout_marginBottom="14dp"
          app:passwordToggleEnabled="true" app:boxStrokeColor="@color/accent_blue">
        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etMasterSetup"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:inputType="textPassword" android:textColor="@color/text_primary"/>
      </com.google.android.material.textfield.TextInputLayout>
      <com.google.android.material.textfield.TextInputLayout
          style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
          android:layout_width="match_parent" android:layout_height="wrap_content"
          android:hint="Confirm Master Password" android:layout_marginBottom="6dp"
          app:passwordToggleEnabled="true" app:boxStrokeColor="@color/accent_blue">
        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etMasterConfirm"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:inputType="textPassword" android:imeOptions="actionDone"
            android:textColor="@color/text_primary"/>
      </com.google.android.material.textfield.TextInputLayout>
      <ProgressBar android:id="@+id/progressSetup" android:layout_width="wrap_content"
          android:layout_height="wrap_content" android:layout_gravity="center"
          android:layout_marginBottom="6dp" android:visibility="gone"/>
      <TextView android:id="@+id/tvSetupError" android:layout_width="match_parent"
          android:layout_height="wrap_content" android:textColor="#FFf87171"
          android:textSize="13sp" android:gravity="center"
          android:layout_marginBottom="10dp" android:visibility="gone"/>
      <Button android:id="@+id/btnSetup" android:layout_width="match_parent"
          android:layout_height="56dp" android:text="CREATE VAULT"
          android:textSize="15sp" android:backgroundTint="@color/accent_blue"/>
    </LinearLayout>

    <!-- LOGIN -->
    <LinearLayout android:id="@+id/layoutLogin" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">

      <!-- Biometric -->
      <LinearLayout android:id="@+id/layoutBiometric" android:layout_width="match_parent"
          android:layout_height="wrap_content" android:orientation="vertical"
          android:gravity="center" android:layout_marginBottom="20dp" android:visibility="gone">
        <Button android:id="@+id/btnBiometric" android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="🫆  Fingerprint / Face Unlock"
            android:textSize="15sp" android:backgroundTint="@color/surface2"/>
        <TextView android:id="@+id/tvBioHint" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Ya neeche Master Password se"
            android:textColor="@color/text_secondary" android:textSize="12sp"
            android:layout_marginTop="10dp"/>
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/border" android:layout_marginVertical="16dp"/>
      </LinearLayout>

      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:text="Master Password" android:textSize="18sp" android:textStyle="bold"
          android:textColor="@color/text_primary" android:layout_marginBottom="16dp"/>

      <com.google.android.material.textfield.TextInputLayout
          style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
          android:layout_width="match_parent" android:layout_height="wrap_content"
          android:hint="Master Password" android:layout_marginBottom="6dp"
          app:passwordToggleEnabled="true" app:boxStrokeColor="@color/accent_blue">
        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etMasterLogin"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:inputType="textPassword" android:imeOptions="actionDone"
            android:textColor="@color/text_primary"/>
      </com.google.android.material.textfield.TextInputLayout>

      <ProgressBar android:id="@+id/progressLogin" android:layout_width="wrap_content"
          android:layout_height="wrap_content" android:layout_gravity="center"
          android:layout_marginVertical="6dp" android:visibility="gone"/>
      <TextView android:id="@+id/tvLoginError" android:layout_width="match_parent"
          android:layout_height="wrap_content" android:textColor="#FFf87171"
          android:textSize="13sp" android:gravity="center"
          android:layout_marginBottom="12dp" android:visibility="gone"/>

      <Button android:id="@+id/btnLogin" android:layout_width="match_parent"
          android:layout_height="56dp" android:text="UNLOCK VAULT"
          android:textSize="15sp" android:backgroundTint="@color/accent_blue"/>

      <TextView android:id="@+id/tvForgot" android:layout_width="wrap_content"
          android:layout_height="wrap_content" android:text="Master Password bhool gaye?"
          android:textColor="@color/accent_blue" android:textSize="13sp"
          android:layout_gravity="center" android:layout_marginTop="16dp"
          android:padding="8dp"/>
    </LinearLayout>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="🔒 AES-256  •  100% Local  •  No Cloud"
        android:textSize="11sp" android:textColor="@color/text_hint"
        android:layout_marginTop="28dp"/>
  </LinearLayout>
</ScrollView>
