<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp"
        android:gravity="center">

        <!-- Logo -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="40dp">

            <TextView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="🔐"
                android:textSize="40sp"
                android:gravity="center"
                android:background="@drawable/circle_bg_blue"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BabaSitaRam Pro"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Password Manager"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- SETUP LAYOUT -->
        <LinearLayout
            android:id="@+id/layoutSetup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="First Time Setup"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="24dp"/>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Mobile Number"
                android:layout_marginBottom="16dp"
                app:boxStrokeColor="@color/accent_blue"
                app:hintTextColor="@color/accent_blue">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone"
                    android:textColor="@color/text_primary"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Master Password"
                android:layout_marginBottom="16dp"
                app:passwordToggleEnabled="true"
                app:boxStrokeColor="@color/accent_blue">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etMasterSetup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textColor="@color/text_primary"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Confirm Master Password"
                android:layout_marginBottom="28dp"
                app:passwordToggleEnabled="true"
                app:boxStrokeColor="@color/accent_blue">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etMasterConfirm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textColor="@color/text_primary"/>
            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/btnSetup"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="CREATE VAULT"
                android:textSize="15sp"
                android:letterSpacing="0.1"
                android:backgroundTint="@color/accent_blue"/>
        </LinearLayout>

        <!-- LOGIN LAYOUT -->
        <LinearLayout
            android:id="@+id/layoutLogin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome Back"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="24dp"/>

            <!-- Biometric section -->
            <LinearLayout
                android:id="@+id/layoutBiometric"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="24dp"
                android:visibility="gone">

                <Button
                    android:id="@+id/btnBiometric"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="🫆  Fingerprint / Face Unlock"
                    android:textSize="16sp"
                    android:backgroundTint="@color/surface2"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="— ya Master Password se —"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"/>
            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Master Password"
                android:layout_marginBottom="24dp"
                app:passwordToggleEnabled="true"
                app:boxStrokeColor="@color/accent_blue">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etMasterLogin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textColor="@color/text_primary"
                    android:imeOptions="actionDone"/>
            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="UNLOCK VAULT"
                android:textSize="15sp"
                android:letterSpacing="0.1"
                android:backgroundTint="@color/accent_blue"/>
        </LinearLayout>

        <!-- Security badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔒 AES-256  •  100% Local  •  No Cloud"
                android:textSize="11sp"
                android:textColor="@color/text_hint"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
